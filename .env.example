# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — for /dashboard to read demo_leads, demo_bookings, demo_form_submissions (optional; otherwise add SELECT policies in Supabase)
# SUPABASE_SERVICE_ROLE_KEY=

# Admin — only this email can access /clients and /dashboard (optional but recommended)
ADMIN_EMAIL=your@email.com

# Email alerts — get notified when someone books a session (optional)
# Get key at resend.com. Uses onboarding@resend.dev for testing; verify your domain for production.
# RESEND_API_KEY=re_xxxxx

# OpenAI (for demo chat)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
