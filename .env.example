# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — for dashboard reads + reliable booking inserts (recommended)
# SUPABASE_SERVICE_ROLE_KEY=

# Supabase database URL — for one-click table setup (optional)
# Get from Supabase → Settings → Database → Connection string (URI)
# SUPABASE_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxx.supabase.co:5432/postgres

# Admin — only this email can access /clients and /dashboard. Booking alerts go here.
ADMIN_EMAIL=nestinghome916@gmail.com

# Email alerts — get notified at ADMIN_EMAIL when someone books a session
# Sign up at resend.com (free tier: 100 emails/day). Use onboarding@resend.dev for testing.
RESEND_API_KEY=re_xxxxx

# OpenAI (for demo chat)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Book a call — defaults to in-house /book page. Set to use Calendly instead:
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username/15min
